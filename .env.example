# API
PORT=3001
NODE_ENV=development
JWT_SECRET=changeme
ACCESS_TOKEN_EXP=15m
REFRESH_TOKEN_EXP=30d

# Auth rate limiting
RATE_LIMIT_LOGIN=5
RATE_LIMIT_REFRESH=10
RATE_LIMIT_WINDOW_SEC=600

# Persistence
REPOSITORY_ADAPTER=memory
DATABASE_URL=postgres://user:pass@localhost:5432/tendersahayak

# Placeholder for future provider integrations
ANTHROPIC_API_KEY=
REDIS_URL=
S3_BUCKET=
